RewriteEngine On

# Base URL for the project (folder name under htdocs)
RewriteBase /Web-Based-Barangay-Information-Management-System/

# If the requested path is not an existing file or directory,
# send it to index.php so the PHP router can handle /login, /register, etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

